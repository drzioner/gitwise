{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitwise.dev/schemas/v1/output/sync.json",
  "title": "gitwise sync cli output",
  "description": "v3 envelope for `gitwise sync --json`. data carries branch, ahead/behind counts, an upstream flag, the unpushed commit subjects, and (dry-run) the planned actions. data is permissive (additional fields allowed).",
  "type": "object",
  "required": ["v", "ok", "command", "data", "hints", "errors"],
  "additionalProperties": false,
  "properties": {
    "v": { "const": 3 },
    "ok": { "type": "boolean" },
    "command": { "const": "sync" },
    "hints": { "type": "array", "items": { "type": "string" } },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "hint": { "type": "string" }
        }
      }
    },
    "data": {
      "type": "object",
      "properties": {
        "branch": { "type": "string" },
        "ahead": { "type": "integer" },
        "behind": { "type": "integer" },
        "upstream": { "type": "boolean" },
        "unpushed": { "type": "array", "items": { "type": "string" } },
        "actions": { "type": "array", "items": { "type": "string" } },
        "dry_run": { "type": "boolean" }
      }
    }
  }
}
