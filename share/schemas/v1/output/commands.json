{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitwise.dev/schemas/v1/output/commands.json",
  "title": "gitwise commands cli output",
  "description": "v3 envelope for `gitwise commands --json`. data.commands lists every subcommand with its help text, aliases, and JSON capability flags. data is permissive (additional fields allowed) to stay forward-compatible.",
  "type": "object",
  "required": ["v", "ok", "command", "data", "hints", "errors"],
  "additionalProperties": false,
  "properties": {
    "v": { "const": 3 },
    "ok": { "type": "boolean" },
    "command": { "const": "commands" },
    "hints": { "type": "array", "items": { "type": "string" } },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "hint": { "type": "string" }
        }
      }
    },
    "data": {
      "type": "object",
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "help", "aliases", "supports_json"],
            "properties": {
              "name": { "type": "string" },
              "help": { "type": "string" },
              "aliases": { "type": "array", "items": { "type": "string" } },
              "supports_json": { "type": "boolean" },
              "supports_json_lines": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
