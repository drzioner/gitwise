{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitwise.dev/schemas/v1/output/context.json",
  "title": "gitwise context cli output",
  "description": "v3 envelope for `gitwise context --json`. data fields enumerated; data is permissive (additional fields allowed) to stay forward-compatible.",
  "type": "object",
  "required": [
    "v",
    "ok",
    "command",
    "data",
    "hints",
    "errors"
  ],
  "additionalProperties": false,
  "properties": {
    "v": {
      "const": 3
    },
    "ok": {
      "type": "boolean"
    },
    "command": {
      "const": "context"
    },
    "hints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "hint": {
            "type": "string"
          }
        }
      }
    },
    "data": {
      "type": "object",
      "properties": {
        "tree": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tree_total": {
          "type": "integer",
          "minimum": 0
        },
        "tree_truncated": {
          "type": "boolean"
        }
      }
    }
  }
}
