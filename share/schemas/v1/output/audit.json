{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitwise.dev/schemas/v1/output/audit.json",
  "title": "gitwise audit cli output",
  "description": "v3 envelope for `gitwise audit --json`. data.findings is a list of diagnostic findings with severity; data.summary aggregates counts. data is permissive (additional fields allowed).",
  "type": "object",
  "required": ["v", "ok", "command", "data", "hints", "errors"],
  "additionalProperties": false,
  "properties": {
    "v": { "const": 3 },
    "ok": { "type": "boolean" },
    "command": { "const": "audit" },
    "hints": { "type": "array", "items": { "type": "string" } },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "hint": { "type": "string" }
        }
      }
    },
    "data": {
      "type": "object",
      "properties": {
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "severity"],
            "properties": {
              "type": { "type": "string" },
              "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
              "message": { "type": "string" },
              "fix": { "type": "string" }
            }
          }
        },
        "summary": {
          "type": "object",
          "properties": {
            "critical": { "type": "integer" },
            "high": { "type": "integer" },
            "medium": { "type": "integer" },
            "low": { "type": "integer" },
            "info": { "type": "integer" }
          }
        }
      }
    }
  }
}
