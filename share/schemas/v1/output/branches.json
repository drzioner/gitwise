{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitwise.dev/schemas/v1/output/branches.json",
  "title": "gitwise branches cli output",
  "description": "v3 envelope for `gitwise branches --json`. data fields enumerated; data is permissive (additional fields allowed) to stay forward-compatible.",
  "type": "object",
  "required": [
    "v",
    "ok",
    "command",
    "data",
    "hints",
    "errors"
  ],
  "additionalProperties": false,
  "properties": {
    "v": {
      "const": 3
    },
    "ok": {
      "type": "boolean"
    },
    "command": {
      "const": "branches"
    },
    "hints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "hint": {
            "type": "string"
          }
        }
      }
    },
    "data": {
      "type": "object",
      "properties": {
        "branches": {
          "type": "integer"
        },
        "count": {
          "type": "integer"
        },
        "stale_branches": {
          "type": "array"
        }
      }
    }
  }
}
