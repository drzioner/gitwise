{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitwise.dev/schemas/v1/input/merge.json",
  "title": "gitwise merge cli input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "lang": {
      "type": "string",
      "enum": [
        "es",
        "en"
      ],
      "description": "output language (default: auto-detect from locale)"
    },
    "theme": {
      "type": "string",
      "enum": [
        "dark",
        "light",
        "auto"
      ],
      "description": "color theme: dark, light, or auto-detect (default: auto)"
    },
    "json": {
      "type": "boolean",
      "description": "output JSON",
      "default": false
    },
    "json_pretty": {
      "type": "boolean",
      "description": "pretty-print JSON output",
      "default": false
    },
    "branch": {
      "type": "string",
      "description": "branch to merge/rebase from (omit with --abort/--continue)"
    },
    "rebase": {
      "type": "boolean",
      "description": "rebase instead of merge",
      "default": false
    },
    "no_ff": {
      "type": "boolean",
      "description": "force no-fast-forward",
      "default": false
    },
    "dry_run": {
      "type": "boolean",
      "description": "show checks without merging",
      "default": false
    },
    "yes": {
      "type": "boolean",
      "description": "skip confirmation",
      "default": false
    },
    "abort": {
      "type": "boolean",
      "description": "abort an in-progress merge or rebase",
      "default": false
    },
    "continue_merge": {
      "type": "boolean",
      "description": "continue an in-progress merge or rebase after resolving conflicts",
      "default": false
    }
  }
}
