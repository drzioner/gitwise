{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitwise.dev/schemas/v1/input/pr.json",
  "title": "gitwise pr cli input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "lang": {
      "type": "string",
      "enum": [
        "es",
        "en"
      ],
      "description": "output language (default: auto-detect from locale)"
    },
    "theme": {
      "type": "string",
      "enum": [
        "dark",
        "light",
        "auto"
      ],
      "description": "color theme: dark, light, or auto-detect (default: auto)"
    },
    "json": {
      "type": "boolean",
      "description": "output JSON",
      "default": false
    },
    "json_pretty": {
      "type": "boolean",
      "description": "pretty-print JSON output",
      "default": false
    },
    "action": {
      "type": "string",
      "enum": [
        "list",
        "checks",
        "view",
        "comments",
        "create"
      ],
      "description": "pr action",
      "default": "list"
    },
    "selector": {
      "type": "string",
      "description": "PR number/url/branch (default: current branch PR)"
    },
    "state": {
      "type": "string",
      "enum": [
        "open",
        "closed",
        "merged",
        "all"
      ],
      "description": "filter by state: open,closed,merged,all (list)"
    },
    "author": {
      "type": "string",
      "description": "filter by author login (list)"
    },
    "label": {
      "type": "string",
      "description": "filter by label (list)"
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "description": "max PRs to list"
    },
    "base": {
      "type": "string",
      "description": "base branch (list/create)"
    },
    "head": {
      "type": "string",
      "description": "head branch (list/create)"
    },
    "title": {
      "type": "string",
      "description": "PR title (create)"
    },
    "body": {
      "type": "string",
      "description": "PR body (create)"
    },
    "draft": {
      "type": "boolean",
      "description": "create as draft",
      "default": false
    },
    "fill": {
      "type": "boolean",
      "description": "use commit info for title/body (create)",
      "default": false
    }
  }
}
