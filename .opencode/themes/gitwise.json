{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "orange": "#E69138",
    "charcoal": "#1A1A1A",
    "parchment": "#F8F6F1",
    "medgray": "#666666",
    "lightgray": "#D1D1D1",
    "termblack": "#121214",
    "mutedgray": "#808080",
    "green": "#4CAF50",
    "red": "#F44336",
    "termblack-light": "#2A2A2E",
    "termblack-lighter": "#333338"
  },
  "theme": {
    "primary": { "dark": "orange", "light": "orange" },
    "secondary": { "dark": "lightgray", "light": "charcoal" },
    "accent": { "dark": "orange", "light": "orange" },
    "error": { "dark": "red", "light": "red" },
    "warning": { "dark": "orange", "light": "orange" },
    "success": { "dark": "green", "light": "green" },
    "info": { "dark": "lightgray", "light": "medgray" },
    "text": { "dark": "lightgray", "light": "charcoal" },
    "textMuted": { "dark": "mutedgray", "light": "medgray" },
    "background": { "dark": "termblack", "light": "parchment" },
    "backgroundPanel": { "dark": "termblack-light", "light": "none" },
    "backgroundElement": { "dark": "termblack-lighter", "light": "none" },
    "border": { "dark": "termblack-lighter", "light": "#E0DDD6" },
    "borderActive": { "dark": "mutedgray", "light": "medgray" },
    "borderSubtle": { "dark": "termblack-light", "light": "#E8E5DE" },
    "diffAdded": { "dark": "green", "light": "#2E7D32" },
    "diffRemoved": { "dark": "red", "light": "#C62828" },
    "diffContext": { "dark": "mutedgray", "light": "medgray" },
    "diffHunkHeader": { "dark": "mutedgray", "light": "medgray" },
    "diffHighlightAdded": { "dark": "#66BB6A", "light": "#A5D6A7" },
    "diffHighlightRemoved": { "dark": "#EF5350", "light": "#EF9A9A" },
    "diffAddedBg": { "dark": "#1A2E1A", "light": "#E8F5E9" },
    "diffRemovedBg": { "dark": "#2E1A1A", "light": "#FFEBEE" },
    "diffContextBg": { "dark": "termblack-light", "light": "none" },
    "diffLineNumber": { "dark": "mutedgray", "light": "medgray" },
    "diffAddedLineNumberBg": { "dark": "#1A2E1A", "light": "#E8F5E9" },
    "diffRemovedLineNumberBg": { "dark": "#2E1A1A", "light": "#FFEBEE" },
    "markdownText": { "dark": "lightgray", "light": "charcoal" },
    "markdownHeading": { "dark": "orange", "light": "charcoal" },
    "markdownLink": { "dark": "orange", "light": "#BF7020" },
    "markdownLinkText": { "dark": "lightgray", "light": "#BF7020" },
    "markdownCode": { "dark": "#A5D6A7", "light": "#2E7D32" },
    "markdownBlockQuote": { "dark": "mutedgray", "light": "medgray" },
    "markdownEmph": { "dark": "lightgray", "light": "charcoal" },
    "markdownStrong": { "dark": "none", "light": "charcoal" },
    "markdownHorizontalRule": { "dark": "termblack-lighter", "light": "#E0DDD6" },
    "markdownListItem": { "dark": "orange", "light": "charcoal" },
    "markdownListEnumeration": { "dark": "orange", "light": "medgray" },
    "markdownImage": { "dark": "orange", "light": "#BF7020" },
    "markdownImageText": { "dark": "lightgray", "light": "medgray" },
    "markdownCodeBlock": { "dark": "lightgray", "light": "charcoal" },
    "syntaxComment": { "dark": "mutedgray", "light": "medgray" },
    "syntaxKeyword": { "dark": "orange", "light": "#BF7020" },
    "syntaxFunction": { "dark": "#90CAF9", "light": "#1565C0" },
    "syntaxVariable": { "dark": "lightgray", "light": "charcoal" },
    "syntaxString": { "dark": "#A5D6A7", "light": "#2E7D32" },
    "syntaxNumber": { "dark": "#CE93D8", "light": "#7B1FA2" },
    "syntaxType": { "dark": "#FFCC80", "light": "#E65100" },
    "syntaxOperator": { "dark": "lightgray", "light": "charcoal" },
    "syntaxPunctuation": { "dark": "mutedgray", "light": "medgray" }
  }
}
